flowchart LR
    CN["commit_notes<br/>(notes finalized)"] --> CR["Credential Resolver<br/>(scan_credentials)"]
    CR --> STEP1["Step 1:<br/>Alias Lookup<br/>(known edge cases)"]
    STEP1 --> STEP2["Step 2:<br/>Hardcoded Map<br/>(NODE_CREDENTIAL_MAP)"]
    STEP2 --> STEP3["Step 3:<br/>Convention Guess<br/>+ n8n API validation"]
    STEP3 --> STEP4["Step 4:<br/>LLM Fallback<br/>(structured output)"]
    STEP4 --> STEP5["Step 5:<br/>Skip with warning"]

    STEP1 -->|found| RES["Resolved credential types"]
    STEP2 -->|found| RES
    STEP3 -->|found| RES
    STEP4 -->|found| RES
    STEP5 -->|not found| SKIP["[]<br/>(empty list)"]

    RES --> CHK["Check n8n<br/>for existing creds"]
    CHK -->|all resolved| CP["commit_preflight<br/>(mark as committed)"]
    CHK -->|missing| ASK["Ask user<br/>for missing creds"]
    ASK --> SV["save_credential<br/>(to n8n)"]
    SV --> CHK

    style CR fill:#4A90E2,stroke:#333,stroke-width:2px,color:#fff
    style STEP1 fill:#4A90E2,stroke:#333,stroke-width:1.5px,color:#fff
    style STEP2 fill:#4A90E2,stroke:#333,stroke-width:1.5px,color:#fff
    style STEP3 fill:#4A90E2,stroke:#333,stroke-width:1.5px,color:#fff
    style STEP4 fill:#4A90E2,stroke:#333,stroke-width:1.5px,color:#fff
    style STEP5 fill:#4A90E2,stroke:#333,stroke-width:1.5px,color:#fff
    style RES fill:#7ED321,stroke:#333,stroke-width:2px,color:#000
    style CHK fill:#7ED321,stroke:#333,stroke-width:1.5px,color:#000
    style CP fill:#7ED321,stroke:#333,stroke-width:2px,color:#000
    style ASK fill:#F5A623,stroke:#333,stroke-width:2px,color:#000
    style SV fill:#F5A623,stroke:#333,stroke-width:1.5px,color:#000
    style SKIP fill:#e5e7eb,stroke:#333,stroke-width:1.5px,color:#000
    style CN fill:#f5f3ff,stroke:#7c3aed,stroke-width:2px,color:#3b0764
