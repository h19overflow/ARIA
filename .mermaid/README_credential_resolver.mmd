flowchart TD
    INT["Integration Name<br/>(e.g. 'Zendesk')"] --> S1{Step 1: Alias?}
    S1 -->|"Hit"| DONE["Credential Type(s)"]
    S1 -->|"Miss"| S2{Step 2: Hardcoded Map?}
    S2 -->|"Hit"| DONE
    S2 -->|"Miss"| S3{Step 3: Convention Guess<br/>+ n8n API Validation}
    S3 -->|"Hit"| CACHE["Cache + Return"]
    S3 -->|"Miss"| S4{Step 4: LLM Fallback<br/>BaseAgent structured output}
    S4 -->|"Match"| CACHE
    S4 -->|"No Match"| S5["Step 5: Skip<br/>(warn + empty list)"]
    CACHE --> DONE

    style INT fill:#e2e8f0,stroke:#64748b,stroke-width:2px,color:#0f172a
    style S1 fill:#fef08a,stroke:#ca8a04,stroke-width:2px,color:#0f172a
    style S2 fill:#fef08a,stroke:#ca8a04,stroke-width:2px,color:#0f172a
    style S3 fill:#bae6fd,stroke:#0284c7,stroke-width:2px,color:#0f172a
    style S4 fill:#ddd6fe,stroke:#7c3aed,stroke-width:2px,color:#0f172a
    style S5 fill:#fecaca,stroke:#dc2626,stroke-width:2px,color:#0f172a
    style CACHE fill:#bbf7d0,stroke:#22c55e,stroke-width:2px,color:#0f172a
    style DONE fill:#86efac,stroke:#16a34a,stroke-width:2px,color:#0f172a
